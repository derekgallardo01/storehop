<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      v0.7.1: declare the Play billing permission so Play Console unlocks
      the in-app products UI. The actual Play Billing Library integration
      lands in a follow-up release — for now the permission alone is what
      Play needs to let us create the Premium IAP in the product catalog.
    -->
    <uses-permission android:name="com.android.vending.BILLING" />

    <application
        android:name=".StorehopApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Storehop">

        <!--
          AppCompatDelegate.setApplicationLocales needs this opt-in when the
          host Activity isn't an AppCompatActivity (we use ComponentActivity
          for Compose-only). With autoStoreLocales=true, AppCompat delegates
          to LocaleManager on API 33+ and uses its own backport on older
          devices; without it the call silently no-ops on ComponentActivity.
        -->
        <meta-data
            android:name="autoStoreLocales"
            android:value="true" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Storehop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>
