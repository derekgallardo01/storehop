# Copy this file to `keystore.properties` (sibling to settings.gradle.kts)
# and fill in your actual values. The real file is gitignored.
#
# After generating the keystore with keytool, point storeFile to its
# absolute path -- keep it OUTSIDE the repo so it can never be
# accidentally committed.
#
# Lose the keystore file or these passwords and you lose the ability
# to publish updates under the same app identity on Google Play.
# Back it up somewhere safe.

storeFile=/absolute/path/to/storehop-release.jks
storePassword=REPLACE_ME
keyAlias=storehop
keyPassword=REPLACE_ME
