    "settings_force_sync_title": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Sync before uninstalling" } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Sincronizar antes de desinstalar" } },
        "es": { "stringUnit": { "state": "translated", "value": "Sincronizar antes de desinstalar" } },
        "it": { "stringUnit": { "state": "translated", "value": "Sincronizza prima di disinstallare" } }
      }
    },
    "settings_force_sync_explainer": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "If you're switching to a new install (uninstall + reinstall), tap this first so every local change reaches the cloud. Cloud-stored data restores automatically when you sign in on the new install." } },
        "pt-PT": { "stringUnit": { "state": "translated", "value": "Se vai trocar de instalação (desinstalar e reinstalar), toque aqui primeiro para que todas as alterações locais cheguem à nuvem. Os dados na nuvem são restaurados automaticamente quando iniciar sessão na nova instalação." } },
        "es": { "stringUnit": { "state": "translated", "value": "Si vas a cambiar de instalación (desinstalar + reinstalar), toca aquí primero para que todos los cambios locales lleguen a la nube. Los datos en la nube se restauran automáticamente al iniciar sesión en la nueva instalación." } },
        "it": { "stringUnit": { "state": "translated", "value": "Se stai passando a una nuova installazione (disinstalla + reinstalla), tocca prima qui in modo che ogni modifica locale raggiunga il cloud. I dati nel cloud vengono ripristinati automaticamente quando accedi alla nuova installazione." } }
      }
    },
    "settings_force_sync_button_idle": {
      "extractionState": "manual",
      "localizations": {
        "en": { "stringUnit": { "state": "translated", "value": "Force sync now" } },
