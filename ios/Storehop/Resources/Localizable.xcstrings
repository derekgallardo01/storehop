{
  "sourceLanguage": "en",
  "strings": {
    "account_anonymous_description": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas neste dispositivo. Inicie sessão para fazer cópia de segurança e sincronizar a sua lista entre dispositivos."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local-only on this device. Sign in to back up + sync your list across devices."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo en este dispositivo. Inicia sesión para hacer copia de seguridad y sincronizar tu lista entre dispositivos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Solo su questo dispositivo. Accedi per fare il backup e sincronizzare la tua lista tra dispositivi."
          }
        }
      }
    },
    "account_anonymous_label": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Conta anónima"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Anonymous account"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuenta anónima"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Account anonimo"
          }
        }
      }
    },
    "account_sign_in_helper": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Os artigos, lojas e fotografias existentes ficam associados à sua conta Google quando inicia sessão — sem perda de dados."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your existing items, stores, and photos transfer to your Google account when you sign in — no data loss."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus artículos, tiendas y fotos existentes se transfieren a tu cuenta de Google al iniciar sesión, sin pérdida de datos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I tuoi articoli, negozi e foto esistenti vengono trasferiti al tuo account Google quando accedi, senza perdere dati."
          }
        }
      }
    },
    "account_sign_out_helper": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminar sessão remove a vista sincronizada deste dispositivo. Os dados na nuvem permanecem seguros na sua conta Google e voltam a aparecer quando iniciar sessão novamente."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Signing out clears the cloud-synced view on this device. Your cloud data stays safe under your Google account and reappears when you sign in again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cerrar sesión elimina la vista sincronizada con la nube de este dispositivo. Tus datos en la nube permanecen seguros en tu cuenta de Google y reaparecen al iniciar sesión de nuevo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Uscire rimuove la vista sincronizzata con il cloud da questo dispositivo. I tuoi dati nel cloud restano al sicuro nel tuo account Google e ricompaiono al successivo accesso."
          }
        }
      }
    },
