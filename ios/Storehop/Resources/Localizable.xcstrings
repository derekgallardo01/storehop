{
  "sourceLanguage": "en",
  "strings": {
    "account_anonymous_description": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Apenas neste dispositivo. Inicie sessão para fazer cópia de segurança e sincronizar a sua lista entre dispositivos."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local-only on this device. Sign in to back up + sync your list across devices."
          }
        }
      }
    },
    "account_anonymous_label": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Conta anónima"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Anonymous account"
          }
        }
      }
    },
    "account_sign_in_helper": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Os artigos, lojas e fotografias existentes ficam associados à sua conta Google quando inicia sessão — sem perda de dados."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your existing items, stores, and photos transfer to your Google account when you sign in — no data loss."
          }
        }
      }
    },
    "account_sign_out_helper": {
      "extractionState": "manual",
      "localizations": {
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Terminar sessão remove a vista sincronizada deste dispositivo. Os dados na nuvem permanecem seguros na sua conta Google e voltam a aparecer quando iniciar sessão novamente."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Signing out clears the cloud-synced view on this device. Your cloud data stays safe under your Google account and reappears when you sign in again."
          }
        }
      }
    },
